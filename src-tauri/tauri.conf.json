{
  "$schema": "https://raw.githubusercontent.com/nickolay/tauri/tauri-v2/tooling/cli/schema.json",
  "productName": "MarkMark",
  "version": "2.0.15",
  "identifier": "com.markmark.win",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MarkMark",
        "width": 1200,
        "height": 800,
        "minWidth": 650,
        "minHeight": 450,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
